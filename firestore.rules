rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net Default-Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Authentication and Administration helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
             request.auth.token.email == 'safeness.c.a@gmail.com';
    }

    // Collection Security Definitions

    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow update: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /domains/{domainId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin()) && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    match /aliases/{aliasId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin()) && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin()) && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    match /contacts/{contactId} {
      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin()) && (request.resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }
  }
}
