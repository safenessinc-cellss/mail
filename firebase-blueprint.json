{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Registered SaaS user profile holding SMTP and storage metrics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "dailySentCount": { "type": "integer" },
        "lastSentDate": { "type": "string" },
        "storageUsedBytes": { "type": "integer" },
        "gmailConnected": { "type": "boolean" },
        "gmailEmail": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "dailySentCount", "storageUsedBytes", "createdAt"]
    },
    "Domain": {
      "title": "Domain",
      "description": "Authenticated user domain with mail routing status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "domainName": { "type": "string" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "ownerId", "domainName", "verified", "createdAt"]
    },
    "EmailAlias": {
      "title": "EmailAlias",
      "description": "Mailbox inbox/alias associated with a domain",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "domainId": { "type": "string" },
        "domainName": { "type": "string" },
        "localPart": { "type": "string" },
        "address": { "type": "string" },
        "forwardTo": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string" },
        "password": { "type": "string" },
        "imapHost": { "type": "string" },
        "imapPort": { "type": "integer" },
        "smtpHost": { "type": "string" },
        "smtpPort": { "type": "integer" },
        "smtpSecure": { "type": "boolean" }
      },
      "required": ["id", "domainId", "domainName", "localPart", "address", "createdAt"]
    },
    "EmailMessage": {
      "title": "EmailMessage",
      "description": "Transmitted/received message records including mail parts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "aliasId": { "type": "string" },
        "aliasAddress": { "type": "string" },
        "fromName": { "type": "string" },
        "fromAddress": { "type": "string" },
        "toAddress": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "createdAt": { "type": "string" },
        "folder": { "type": "string" },
        "read": { "type": "boolean" },
        "isGmail": { "type": "boolean" }
      },
      "required": ["id", "ownerId", "aliasId", "aliasAddress", "fromAddress", "toAddress", "subject", "body", "createdAt", "folder", "read"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Direct contact entry used in dynamic lookups",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "ownerId", "name", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Individual profiles for SMTP limit enforcement and metadata"
    },
    "/domains/{domainId}": {
      "schema": { "$ref": "#/entities/Domain" },
      "description": "Customer domains with host-level verification statuses"
    },
    "/aliases/{aliasId}": {
      "schema": { "$ref": "#/entities/EmailAlias" },
      "description": "Virtual aliases mapped to domainId and ownerId"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/EmailMessage" },
      "description": "Email traffic records containing content body"
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Address book entries owned by an authentic user"
    }
  }
}
